{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "cleanUrls": true,
  "github": {
    "silent": true,
    "autoAlias": true
  },
  "env": {
    "NEXT_PUBLIC_SITE_URL": {
      "type": "string"
    },
    "NEXT_PUBLIC_SUPABASE_URL": {
      "type": "string"
    },
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": {
      "type": "string"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
} 